# Copia a .env.local para desarrollo. No commitees secretos.

# --- LLM: al menos una es obligatoria en producción ---
# OpenAI (fallback si Gemini no esta configurado)
OPENAI_API_KEY=
# Modelo de OpenAI (opcional; por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Gemini (preferido por el orquestador cuando hay clave)
# GEMINI_API_KEY=

# Voz sintética (opcional). Si se define, el botón "Escuchar" usa ElevenLabs
# con voces por agente. Si no, usa la voz del navegador como fallback.
ELEVENLABS_API_KEY=

# Modelos Gemini en orden de fallback (opcional; por defecto usa este orden)
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-3.5-flash,gemini-2.5-flash,gemini-3-flash

# Presupuesto de "thinking" interno del modelo (Gemini 2.5+). En tokens.
#   0  → desactivado (recomendado para posturas cortas; menor latencia y costo)
#  >0  → permite N tokens de razonamiento interno antes de generar texto visible
# Si no se define, se aplica 0 por defecto.
# GEMINI_THINKING_BUDGET=0

# URL pública de la app (opcional en dev; recomendada en Vercel para sitemap/OAuth)
# Ejemplo producción: https://councilia.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Área A6 / J1; opcional hasta conectar persistencia)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Solo servidor. Necesaria para revisar si un correo ya existe antes de registrar.
SUPABASE_SERVICE_ROLE_KEY=

# Logging (opcional). Niveles: debug | info | warn | error.
# LOG_LEVEL=info

# Solo CI o builds sin secretos: desactiva validación estricta (nunca en prod real)
# SKIP_ENV_VALIDATION=1
