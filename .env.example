# Gemini primary provider. Prefer the plural list for scalable free quota.
GEMINI_API_KEYS=AIza_first_key,AIza_second_key

# Backward-compatible single-key form. Leave empty if using GEMINI_API_KEYS.
GEMINI_API_KEY=

# Tried in order for every Gemini key.
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-3.5-flash,gemini-2.5-flash,gemini-3-flash
GEMINI_THINKING_BUDGET=0

# Paid fallback when all Gemini key/model attempts fail.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
