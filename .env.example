# Copy this file to .env.local for local development.
# Keep real secrets only in .env.local or your hosting provider's env settings.

# Public app URL. Required for auth redirects, sitemap, and OAuth callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose this in client code.
# Used for email lookup, avatar upload, and other privileged server routes.
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider keys. Production requires at least one of these.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Gemini models in fallback order. The app reads GEMINI_MODELS, not GEMINI_MODEL.
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-3.5-flash,gemini-2.5-flash

# Gemini 2.5+ thinking budget in tokens. Use 0 for lower latency/cost.
GEMINI_THINKING_BUDGET=0

# Optional OpenAI model override.
# OPENAI_MODEL=gpt-4o-mini

# Optional logging level: debug | info | warn | error.
# LOG_LEVEL=info

# Stripe (test or live). Publishable key is safe for the browser bundle.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only. Used by API routes, webhooks, and the Stripe MCP server in Cursor.
STRIPE_SECRET_KEY=

# Stripe catalog (product + price IDs creados en el sandbox).
STRIPE_PRODUCT_PLUS=
STRIPE_PRODUCT_PRO=
STRIPE_PRICE_PLUS_MONTHLY_MXN=
STRIPE_PRICE_PLUS_ANNUAL_MXN=
STRIPE_PRICE_PRO_MONTHLY_MXN=
STRIPE_PRICE_PRO_ANNUAL_MXN=
# Lookup keys (preferido vs price IDs hardcodeados).
STRIPE_LOOKUP_PLUS_MONTHLY=councilia_plus_monthly_mxn
STRIPE_LOOKUP_PLUS_ANNUAL=councilia_plus_annual_mxn
STRIPE_LOOKUP_PRO_MONTHLY=councilia_pro_monthly_mxn
STRIPE_LOOKUP_PRO_ANNUAL=councilia_pro_annual_mxn

# Webhook secret. Para desarrollo local:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# y pegar el `whsec_...` que devuelve.
STRIPE_WEBHOOK_SECRET=

# CI/builds without secrets only. Do not use in real production.
# SKIP_ENV_VALIDATION=1

# Playwright E2E (solo local/CI de pruebas; nunca en producción).
# E2E_TEST_MODE=1
# E2E_TEST_SECRET=change-me-local-e2e
# E2E_TEST_EMAIL=tu-usuario-de-prueba@example.com
# E2E_TEST_PASSWORD=tu-password-de-prueba
# PLAYWRIGHT_BASE_URL=http://localhost:3000
