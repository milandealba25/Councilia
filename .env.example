# Copia a .env.local para desarrollo. No commitees secretos.

# --- Obligatoria en producción (Vercel, etc.) ---
ANTHROPIC_API_KEY=

# Modelo para scripts / orquestador (opcional)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# URL pública de la app (opcional en dev; útil para enlaces absolutos y OAuth más adelante)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Área A6 / J1; opcional hasta conectar persistencia)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Solo CI o builds sin secretos: desactiva validación estricta (nunca en producción real)
# SKIP_ENV_VALIDATION=1
