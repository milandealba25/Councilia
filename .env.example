# Copy this file to .env.local for local development.
# Keep real secrets only in .env.local or your hosting provider's env settings.

# Public app URL. Required for auth redirects, sitemap, and OAuth callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project settings.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose this in client code.
# Used for email lookup, avatar upload, and other privileged server routes.
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider keys. Production requires at least one of these.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Gemini models in fallback order. The app reads GEMINI_MODELS, not GEMINI_MODEL.
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-3.5-flash,gemini-2.5-flash

# Gemini 2.5+ thinking budget in tokens. Use 0 for lower latency/cost.
GEMINI_THINKING_BUDGET=0

# Optional voice synthesis. Without this, voice features use browser fallback.
ELEVENLABS_API_KEY=

# Optional OpenAI model override.
# OPENAI_MODEL=gpt-4o-mini

# Optional logging level: debug | info | warn | error.
# LOG_LEVEL=info

# CI/builds without secrets only. Do not use in real production.
# SKIP_ENV_VALIDATION=1
